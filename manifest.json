{
  "manifest_version": 3,
  "name": "PageTalk",
  "version": "1.0.0",
  "description": "Discuss any webpage with other readers. PageTalk attaches a Reddit-style comment thread to every URL so you can share thoughts, reactions, and links with anyone visiting the same page.",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PageTalk - Discuss this page",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
